# Copy this file to .env and fill with real values.
# For Gmail, use an App Password (not your normal Gmail password).

SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

# Sender account used to authenticate with SMTP
EMAIL_HOST_USER=your-address@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Address shown as the sender in outgoing emails
DEFAULT_FROM_EMAIL=your-address@gmail.com

# Inbox that receives contact form submissions
UNIVERSITY_CONTACT_EMAIL=your-inbox@gmail.com
